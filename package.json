{
  "name": "zkproject",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @zkproject/web",
    "dev:relayer": "npm run dev --workspace @zkproject/relayer",
    "e2e:hardhat-local": "node scripts/hardhat-local-e2e.mjs",
    "e2e:hardhat-local-pool": "node scripts/hardhat-local-erc20-pool-e2e.mjs",
    "e2e:sepolia": "node scripts/sepolia-e2e.mjs",
    "e2e:sepolia-pool": "node scripts/sepolia-erc20-pool-e2e.mjs",
    "lint:web": "npm run lint --workspace @zkproject/web",
    "build:web": "npm run build --workspace @zkproject/web",
    "check:sdk": "npm run check --workspace @zkproject/sdk",
    "test:contracts": "cd packages/contracts && forge test",
    "build:contracts": "cd packages/contracts && forge build",
    "deploy:mock-tokens-batch": "node scripts/deploy-mock-erc20-batch.mjs",
    "mint:mock-tokens-batch": "MINT_ONLY=1 node scripts/deploy-mock-erc20-batch.mjs",
    "build:circuits": "cd packages/circuits && nargo compile",
    "test:relayer-smoke": "node services/relayer/test/smoke.mjs",
    "check": "npm run check:sdk && npm run lint:web && npm run build:web"
  },
  "dependencies": {
    "ethers": "^6.16.0",
    "poseidon2-evm": "^1.0.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
