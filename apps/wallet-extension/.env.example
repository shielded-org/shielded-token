# Copy to apps/wallet-extension/.env.local for local dev (Vite bakes env at build/dev time).
# .env.local overrides this file and is gitignored (same pattern as apps/web).

VITE_RELAYER_URL=https://shielded-token.onrender.com

# Read RPC mirrors (same as apps/web — see apps/web/lib/rpc-read.ts)
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
VITE_BASE_SEPOLIA_RPC_URLS=https://sepolia.base.org,https://base-sepolia-rpc.publicnode.com

VITE_ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
VITE_ARBITRUM_SEPOLIA_RPC_URLS=https://sepolia-rollup.arbitrum.io/rpc,https://arbitrum-sepolia-rpc.publicnode.com

# Optional overrides (defaults use canonical pool deploys in src/networks.ts)
# VITE_BASE_SEPOLIA_POOL_ADDRESS=0xA4421d963f0C89FaAF489FfFC0eb662Fc67C030F
# VITE_ARBITRUM_SEPOLIA_POOL_ADDRESS=0x3AD3c6ffE9323A58bcf4ADF3E091E07eC6570976
