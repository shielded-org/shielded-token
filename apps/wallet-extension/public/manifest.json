{
  "manifest_version": 3,
  "name": "Shielded",
  "version": "0.1.0",
  "description": "EOA wallet with Sepolia shielded pool discovery and transfer controls.",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "shielded-icon-tight.png",
      "32": "shielded-icon-tight.png",
      "48": "shielded-icon-tight.png",
      "128": "shielded-icon-tight.png"
    }
  },
  "icons": {
    "16": "shielded-icon-tight.png",
    "32": "shielded-icon-tight.png",
    "48": "shielded-icon-tight.png",
    "128": "shielded-icon-tight.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://ethereum-sepolia-rpc.publicnode.com/*",
    "http://127.0.0.1:8787/*",
    "http://localhost:8787/*",
    "http://0.0.0.0:8787/*"
  ]
}
