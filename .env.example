# Chain and deployment
CHAIN_ID=84532
RPC_URL=
DEPLOYER_PRIVATE_KEY=

# Shielded token settings
TOKEN_NAME=Shielded Token
TOKEN_SYMBOL=SHLD
MERKLE_DEPTH=20
ROOT_HISTORY_SIZE=30

# Relayer
RELAYER_PORT=8787
RELAYER_SIGNER_PRIVATE_KEYS=
RELAYER_SIGNER_PRIVATE_KEY=
RELAYER_RPC_URL=
# Optional multi-testnet (see services/relayer/README.md)
RELAYER_RPC_URL_ETH_SEPOLIA=
RELAYER_RPC_URL_BASE_SEPOLIA=
RELAYER_RPC_URL_ARBITRUM_SEPOLIA=
RELAYER_PRIMARY_CHAIN_ID=
RELAYER_URL=http://127.0.0.1:8787

# Web app
NEXT_PUBLIC_CHAIN_ID=84532
NEXT_PUBLIC_RELAYER_URL=http://localhost:8787
NEXT_PUBLIC_SHIELDED_TOKEN_ADDRESS=
# Optional comma-separated fallbacks for app-side JSON-RPC reads (balances, scans, poseidon); does not change wallet broadcast RPC.
# NEXT_PUBLIC_ETH_SEPOLIA_RPC_URLS=https://rpc.sepolia.org,https://ethereum-sepolia-rpc.publicnode.com
# NEXT_PUBLIC_BASE_SEPOLIA_RPC_URLS=…  # optional: comma-separated, tried first (e.g. Alchemy, then public). Built-in fallbacks: official Base → PublicNode → Tenderly.
# NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC_URLS=…  # same for Arbitrum Sepolia (official rollup → PublicNode → Tenderly).
# NEXT_PUBLIC_SHIELDED_SCAN_DEBUG=true  # OR in browser localStorage key zkproject:shieldedScanDebug = 1 then reload

# Sepolia E2E (scripts/sepolia-e2e.mjs) — use: node --env-file=.env.sepolia scripts/sepolia-e2e.mjs
# Never commit a file that contains PRIVATE_KEY.
TESTNET_NAME=sepolia
TESTNET_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
TESTNET_CHAIN_ID=11155111
BLOCK_EXPLORER_BASE_URL=https://sepolia.etherscan.io
PRIVATE_KEY=
FEE_RECIPIENT_PK=0x000000000000000000000000000000000000000000000000000000000001e240
SKIP_DEPLOY=0
TRANSFERS_ONLY=0
TOKEN_DEPLOY_BLOCK=
SEPOLIA_POSEIDON=
SEPOLIA_POSEIDON_HASHER=
SEPOLIA_VERIFIER=
SEPOLIA_MERKLE_TREE=
SEPOLIA_SHIELDED_TOKEN=
