# Copy to .env.arbitrum-sepolia and set PRIVATE_KEY (never commit secrets).
# Pool deploy: npm run deploy:pool:arbitrum-sepolia
#   or: node --env-file=.env.arbitrum-sepolia scripts/arbitrum-sepolia-pool-deploy.mjs
#
# Mock stables (USDC/USDT/DAI/LINK): after pool deploy, run deploy-mock-erc20-batch with same RPC/key:
#   TESTNET_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
#   TESTNET_CHAIN_ID=421614
#   TESTNET_NAME=arbitrum-sepolia
#   BLOCK_EXPLORER_BASE_URL=https://sepolia.arbiscan.io
#   DEPLOYMENT_JSON=scripts/arbitrum-sepolia-mock-erc20-deployment.json
#   npm run deploy:mock-tokens-batch
#
# Enable pool tokens: node --env-file=.env.arbitrum-sepolia scripts/enable-pool-tokens.mjs

TESTNET_NAME=arbitrum-sepolia
TESTNET_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
TESTNET_CHAIN_ID=421614
BLOCK_EXPLORER_BASE_URL=https://sepolia.arbiscan.io

PRIVATE_KEY=

RELAYER_RPC_URL_ARBITRUM_SEPOLIA=https://sepolia-rollup.arbitrum.io/rpc

# --- App wiring (after deploy): web + extension only need the pool when using the canonical
# deploy baked into networks.ts; otherwise mirror scripts/arbitrum-sepolia-pool-deployment.json.
# apps/web/.env.local:
# NEXT_PUBLIC_ARBITRUM_SEPOLIA_POOL_ADDRESS=0x3AD3c6ffE9323A58bcf4ADF3E091E07eC6570976
# apps/wallet-extension (.env.local or build env):
# VITE_ARBITRUM_SEPOLIA_POOL_ADDRESS=0x3AD3c6ffE9323A58bcf4ADF3E091E07eC6570976

# Same flow as Base / Sepolia pool E2E (see scripts/sepolia-erc20-pool-e2e.mjs).
# DEPLOY_MOCK_TOKEN=1
# TESTNET_POOL_TOKEN_ADDRESS=
