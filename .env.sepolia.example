# Copy to .env.sepolia and set PRIVATE_KEY (never commit .env.sepolia).
# Run: node --env-file=.env.sepolia scripts/sepolia-e2e.mjs

TESTNET_NAME=sepolia
TESTNET_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
TESTNET_CHAIN_ID=11155111
BLOCK_EXPLORER_BASE_URL=https://sepolia.etherscan.io

PRIVATE_KEY=

RELAYER_URL=http://127.0.0.1:8787
RELAYER_CONFIRM_TIMEOUT_MS=600000
RELAYER_POLL_INTERVAL_MS=3000
FEE_RECIPIENT_PK=0x000000000000000000000000000000000000000000000000000000000001e240
ETHERSCAN_API_KEY=
VERIFY_CONTRACTS=1

# SKIP_DEPLOY=1
# TRANSFERS_ONLY=1
# TOKEN_DEPLOY_BLOCK=

# SEPOLIA_POSEIDON=
# SEPOLIA_POSEIDON_HASHER=
# SEPOLIA_VERIFIER=
# SEPOLIA_MERKLE_TREE=
# SEPOLIA_SHIELDED_TOKEN=

# Sepolia multi-token pool E2E (scripts/sepolia-erc20-pool-e2e.mjs)
# Set TESTNET_POOL_TOKEN_ADDRESS to an existing Sepolia ERC20 for real runs.
# If you want demo-only token deployment on Sepolia, set DEPLOY_MOCK_TOKEN=1.
# SKIP_DEPLOY=1 reuses deployment from scripts/sepolia-pool-deployment.json or env below.
# DEPLOY_MOCK_TOKEN=0
# TESTNET_POOL_TOKEN_ADDRESS=
# SEPOLIA_POOL_POSEIDON=
# SEPOLIA_POOL_POSEIDON_HASHER=
# SEPOLIA_POOL_VERIFIER=
# SEPOLIA_POOL_MERKLE_TREE=
# SEPOLIA_POOL_ADDRESS=
# SEPOLIA_POOL_TOKEN=
