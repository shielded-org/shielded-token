# Copy to .env.sepolia and set PRIVATE_KEY (never commit .env.sepolia).
# Run: node --env-file=.env.sepolia scripts/sepolia-e2e.mjs

TESTNET_NAME=sepolia
TESTNET_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
TESTNET_CHAIN_ID=11155111
BLOCK_EXPLORER_BASE_URL=https://sepolia.etherscan.io

PRIVATE_KEY=

RELAYER_URL=http://127.0.0.1:8787
RELAYER_CONFIRM_TIMEOUT_MS=600000
RELAYER_POLL_INTERVAL_MS=3000
ETHERSCAN_API_KEY=
VERIFY_CONTRACTS=1

# SKIP_DEPLOY=1
# TRANSFERS_ONLY=1
# TOKEN_DEPLOY_BLOCK=

